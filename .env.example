# Replacarr Environment Configuration
# Copy this file to .env.local and fill in your values
# These are SERVER-SIDE only — never exposed to the browser

# ── Settings persistence ───────────────────────────────────────────────────────
# Path where Replacarr stores your settings (service URLs, API keys, preferences)
# Defaults to /data/settings.json in Docker; override for local dev if needed
# SETTINGS_FILE=/data/settings.json

# ── TMDB (The Movie Database) ──────────────────────────────────────────────────
# Optional: set a server-side fallback API key.
# Otherwise configure your key in the app's Settings → TMDB section.
# Get a free key at https://www.themoviedb.org/settings/api
# TMDB_API_KEY=your_tmdb_api_key_here

# ── Sonarr ─────────────────────────────────────────────────────────────────────
# Optional server-side fallback; the app stores these in settings.json by default
# SONARR_URL=http://localhost:8989
# SONARR_API_KEY=your_sonarr_api_key_here

# ── Radarr ─────────────────────────────────────────────────────────────────────
# RADARR_URL=http://localhost:7878
# RADARR_API_KEY=your_radarr_api_key_here

# ── SABnzbd ────────────────────────────────────────────────────────────────────
# SABNZBD_URL=http://localhost:8080
# SABNZBD_API_KEY=your_sabnzbd_api_key_here

# ── qBittorrent ────────────────────────────────────────────────────────────────
# QBITTORRENT_URL=http://localhost:8080
# QBITTORRENT_USERNAME=admin
# QBITTORRENT_PASSWORD=your_qbittorrent_password_here
